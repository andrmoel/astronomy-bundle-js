{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "noEmit": true,
        "strict": true,
        "esModuleInterop": true,
        "outDir": "./dist",
        "ignoreDeprecations": "6.0",
        "types": ["jest", "node"],
        "paths": {
            "@app/*": ["./app/*"],
            "@package/*": ["./packages/*"]
        }
    },
    "include": ["app/**/*", "packages/**/*"],
    "exclude": ["node_modules", "dist"]
}
