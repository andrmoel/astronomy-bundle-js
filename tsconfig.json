{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@app/*": ["./app/*"],
      "@package/*": ["./packages/*"]
    }
  },
  "include": ["app/**/*", "packages/**/*"],
  "exclude": ["node_modules", "dist"]
}
